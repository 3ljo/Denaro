# Supabase project URL — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/publishable key — found in Project Settings > API
# This is SAFE to expose to the browser. RLS protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# We do NOT need the service_role key for this auth flow.
# Do NOT add it here. Only add it if you have a specific admin action that
# truly needs it, and only on the server.
