# Supabase project URL — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/publishable key — found in Project Settings > API
# This is SAFE to expose to the browser. RLS protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# Supabase service-role key — found in Project Settings > API
# REQUIRED for the "Delete account" action in /settings (the anon key cannot
# delete auth users). Server-only — never expose to the browser. Add the
# same value as an env var in Vercel for production.
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# OpenAI — required for the Denaro AI analyst (server-only, never exposed)
# Generate at https://platform.openai.com/api-keys
# Add the same value as an env var in Vercel for production.
OPENAI_API_KEY=sk-proj-...
